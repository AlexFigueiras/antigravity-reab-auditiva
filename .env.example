# Copie este arquivo para `.env` e preencha com suas credenciais reais.
# O arquivo `.env` NUNCA deve ser commitado (está no .gitignore).

# Supabase
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Google Cloud Text-to-Speech.
# ATENCAO: chave faturavel. NAO embarcar no cliente em producao —
# o ideal e fazer proxy via Supabase Edge Function. Restrinja a chave
# por API e por aplicativo no console do Google Cloud.
GOOGLE_TTS_API_KEY=AIzaSy_SUA_CHAVE_AQUI
